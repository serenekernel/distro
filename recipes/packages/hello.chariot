source/hello {
    url: "hello_world"
    type: "local"
}

@collection mlibc_build = [ tool/binutils tool/gcc package/mlibc package/mlibc_headers ]

package/hello {
    dependencies: [ source/hello collection/mlibc_build ]
    options: [ ]
    build: <sh>
        x86_64-serene-gcc -o $BUILD_DIR/hello.elf $SOURCES_DIR/hello/hello.c
    </sh>
    install: <sh>cp $BUILD_DIR/hello.elf $INSTALL_DIR/hello.elf</sh>
}
