custom/initramfs {
    dependencies: [ custom/kernel ]
    options: [ "arch" ]
    build: <sh>
        mkdir -p initramfs

        # if [ "$OPTION_arch" = "x86_64" ]; then
            # cp $SYSROOT_DIR/usr/bin/*.elf ./initramfs/
        # fi

        (cd initramfs && tar -cf ../initramfs.tar .)
        rm -r initramfs
    </sh>
    install: <sh>install initramfs.tar $INSTALL_DIR</sh>
}
